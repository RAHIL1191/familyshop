rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "RAHIL1191@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.stockQuantity is number && data.stockQuantity >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000));
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId.size() < 128 &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             data.status in ['pending', 'processing', 'out-for-delivery', 'delivered', 'cancelled'] &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.createdAt == request.time &&
             data.deliveryAddress is string && data.deliveryAddress.size() < 500;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      
      allow update: if (isAdmin() && isValidProduct(incoming())) || 
                     (
                       // Action: Stock Deduction during checkout
                       // Anyone can decrement stock if it's the only change
                       isValidId(productId) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['stockQuantity']) &&
                       incoming().stockQuantity < existing().stockQuantity &&
                       incoming().stockQuantity >= 0
                     );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'customer';
      allow update: if (isOwner(userId) && incoming().role == existing().role) || isAdmin();
    }

    match /orders/{orderId} {
      // Secure list queries: users can only see their own orders
      allow list: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      
      // Get single order: owner, admin, or guest with valid ID
      allow get: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                    (resource.data.userId == 'guest' && isValidId(orderId));
      
      allow create: if (
                        (isAuthenticated() && incoming().userId == request.auth.uid) || 
                        (incoming().userId == 'guest')
                      ) && isValidOrder(incoming());

      allow update: if isAdmin() || 
                    (isOwner(existing().userId) && existing().status == 'pending' && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated();
      // Write only via console
    }
  }
}
