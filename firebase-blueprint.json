{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item available for sale in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Detailed description" },
        "category": { "type": "string", "description": "Category (e.g., Snacks, Drinks, Groceries)" },
        "price": { "type": "number", "description": "Price in GBP" },
        "stockQuantity": { "type": "number", "description": "Current inventory level" },
        "imageUrl": { "type": "string", "format": "url", "description": "Image of the product" }
      },
      "required": ["name", "price", "category", "stockQuantity"]
    },
    "User": {
      "title": "User",
      "description": "App user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "address": { "type": "string", "description": "Default delivery address" }
      },
      "required": ["email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the customer" },
        "items": { "type": "array", "description": "List of ordered items" },
        "status": { "type": "string", "enum": ["pending", "processing", "out-for-delivery", "delivered", "cancelled"] },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "string" },
        "tracking": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "lastUpdated": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["userId", "items", "status", "totalAmount", "createdAt", "deliveryAddress"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store inventory"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
